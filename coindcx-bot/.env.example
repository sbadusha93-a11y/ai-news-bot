# CoinDCX API Credentials
COINDCX_API_KEY=your_api_key_here
COINDCX_API_SECRET=your_api_secret_here

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/coindcx_bot
REDIS_URL=redis://localhost:6379/0

# Alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
DISCORD_WEBHOOK_URL=your_discord_webhook_url
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ALERT_EMAIL=alert@example.com

# Dashboard
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=admin123

# Sentiment API Keys
NEWSAPI_KEY=your_newsapi_key
TWITTER_BEARER_TOKEN=your_twitter_token

# ML Settings
ML_TRAINING_ENABLED=true
ML_MODEL_PATH=data/models

# Bot Settings
BOT_MODE=paper  # paper | live
LOG_LEVEL=INFO
MAX_POSITIONS=3
MAX_RISK_PER_TRADE=1.0

# Railway Settings (set these via Railway dashboard env vars)
RAILWAY_LITE_MODE=true            # Enables memory optimizations for Railway
RAILWAY_VOLUME_PATH=/data         # Railway persistent volume mount path

# Dashboard → Bot API (Required for Railway with separate containers)
# Set this on the DASHBOARD service so it can find the bot's API.
# Format: http://<bot-service-name>:8080
BOT_API_URL=http://localhost:8080
