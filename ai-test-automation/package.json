{
  "name": "ai-test-automation-solution",
  "version": "1.0.0",
  "description": "AI-Powered Test Automation Solution - Generates complete test artifacts from requirements documents",
  "main": "dist/src/main.js",
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/main.ts",
    "dev": "ts-node-dev --respawn src/main.ts",
    "generate": "npm run build && node dist/src/main.js",
    "test": "npx playwright test --config=playwright.config.ts",
    "test:headed": "npx playwright test --headed --config=playwright.config.ts",
    "test:parallel": "npx playwright test --workers=4 --config=playwright.config.ts",
    "report": "npx playwright show-report reports/",
    "clean": "rimraf dist output/reports output/test-data",
    "lint": "npx tsc --noEmit"
  },
  "dependencies": {
    "xlsx": "^0.18.5",
    "pdf-parse": "^1.1.1",
    "mammoth": "^1.6.0",
    "handlebars": "^4.7.8",
    "dotenv": "^16.3.1",
    "fs-extra": "^11.2.0",
    "uuid": "^9.0.0",
    "csv-parse": "^5.5.3",
    "csv-stringify": "^6.4.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@types/fs-extra": "^11.0.4",
    "@types/pdf-parse": "^1.1.4",
    "typescript": "^5.3.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "rimraf": "^5.0.5"
  }
}
